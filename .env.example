# ─────────────────────────────────────────────────────────────────────────────
# LANDLORDZS — Environment Variable Template
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real credentials.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── Application ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-production-domain.com

# ─── MTN Mobile Money ─────────────────────────────────────────────────────────
# Portal: https://momodeveloper.mtn.com
# Sandbox:    MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com  |  TARGET_ENV=sandbox
# Production: MTN_MOMO_BASE_URL=https://proxy.momoapi.mtn.com          |  TARGET_ENV=production

MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MTN_MOMO_TARGET_ENV=sandbox

# Collections product — required for wallet top-ups
MTN_MOMO_SUBSCRIPTION_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MTN_MOMO_API_USER=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MTN_MOMO_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Disbursements product — required for payouts
# Sandbox: may use the same values as Collections above
# Production: subscribe separately for distinct credentials
MTN_MOMO_DISBURSEMENT_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MTN_MOMO_DISBURSEMENT_USER=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MTN_MOMO_DISBURSEMENT_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Async webhook for payment status (must be a public HTTPS URL)
MTN_MOMO_CALLBACK_URL=https://your-domain.com/api/payments/webhook/mtn

# ─── Orange Money Cameroon ────────────────────────────────────────────────────
# Portal: https://developer.orange.com → My Apps → Subscribe to OM WebPay CM

ORANGE_MONEY_BASE_URL=https://api.orange.com
ORANGE_MONEY_CLIENT_ID=your-orange-client-id
ORANGE_MONEY_CLIENT_SECRET=your-orange-client-secret
ORANGE_MONEY_MERCHANT_KEY=your-orange-merchant-key
ORANGE_MONEY_RETURN_URL=https://your-domain.com/payment/success
ORANGE_MONEY_CANCEL_URL=https://your-domain.com/payment/cancelled
ORANGE_MONEY_NOTIF_URL=https://your-domain.com/api/payments/webhook/orange
